# DeOpt v2 Base Sepolia deployment rehearsal environment.
#
# Safe to commit. This file contains no real private keys and no Anvil keys.
# Copy to .env.base-sepolia, replace every REQUIRED_* / FILL_* value, then load
# it before each script phase:
#
#   set -a
#   source .env.base-sepolia
#   set +a
#
# Required values are marked with REQUIRED_. Values marked FILL_FROM_DEPLOY_CORE
# must be replaced after script/DeployCore.s.sol prints deployed addresses.
# Values marked FILL_AFTER_TESTNET_ASSETS or FILL_AFTER_TESTNET_FEEDS must be
# replaced only if the rehearsal uses mock testnet assets/feeds.

# ---------------------------------------------------------------------------
# Common / Base Sepolia
# ---------------------------------------------------------------------------

RPC_URL=REQUIRED_BASE_SEPOLIA_RPC_URL
CHAIN_ID=84532

# REQUIRED. Use a funded Base Sepolia deployer key. Do not commit the filled file.
DEPLOYER_PRIVATE_KEY=REQUIRED_PRIVATE_KEY_DO_NOT_COMMIT
DEPLOYER_ADDRESS=REQUIRED_DEPLOYER_ADDRESS

# Optional Foundry / Basescan verification inputs.
BASESCAN_API_KEY=OPTIONAL_BASESCAN_API_KEY
ETHERSCAN_API_KEY=OPTIONAL_BASESCAN_API_KEY
VERIFIER=etherscan
VERIFIER_URL=https://api-sepolia.basescan.org/api

# ---------------------------------------------------------------------------
# Testnet mock controls
# ---------------------------------------------------------------------------

# Keep false when using externally supplied testnet tokens and oracle sources.
# Set true only for controlled Base Sepolia mock rehearsals.
TESTNET_MOCKS_ENABLED=false
DEPLOY_TESTNET_MOCK_USDC=true
DEPLOY_TESTNET_MOCK_ETH=true
DEPLOY_TESTNET_MOCK_BTC=true
DEPLOY_TESTNET_SECONDARY_FEEDS=true
TESTNET_MOCK_TOKEN_OWNER=REQUIRED_TESTNET_MOCK_TOKEN_OWNER_OR_DEPLOYER
TESTNET_MOCK_MINT_RECEIVER=REQUIRED_TESTNET_MOCK_MINT_RECEIVER_OR_DEPLOYER
TESTNET_MOCK_USDC_MINT_AMOUNT=0
TESTNET_MOCK_ETH_MINT_AMOUNT=0
TESTNET_MOCK_BTC_MINT_AMOUNT=0

# ---------------------------------------------------------------------------
# Roles
# ---------------------------------------------------------------------------

GOVERNANCE_OWNER=REQUIRED_GOVERNANCE_OWNER
TIMELOCK_OWNER=REQUIRED_TIMELOCK_OWNER
RISK_GOVERNOR_OWNER=REQUIRED_RISK_GOVERNOR_OWNER
FINAL_GOVERNANCE_OWNER=REQUIRED_FINAL_GOVERNANCE_OWNER
GOVERNANCE_GUARDIAN=REQUIRED_GOVERNANCE_GUARDIAN
MATCHING_EXECUTOR=REQUIRED_OPTIONS_MATCHING_EXECUTOR
PERP_MATCHING_EXECUTOR=REQUIRED_PERP_MATCHING_EXECUTOR
INSURANCE_OPERATOR=REQUIRED_INSURANCE_OPERATOR

# Required only if AcceptOwnerships is run by EOA owners instead of through a
# timelock execution path. Do not commit real values in .env.base-sepolia.
GOVERNANCE_OWNER_PRIVATE_KEY=REQUIRED_IF_EOA_GOVERNANCE_OWNER
TIMELOCK_OWNER_PRIVATE_KEY=REQUIRED_IF_EOA_TIMELOCK_OWNER
RISK_GOVERNOR_OWNER_PRIVATE_KEY=REQUIRED_IF_EOA_RISK_GOVERNOR_OWNER
FINAL_GOVERNANCE_OWNER_PRIVATE_KEY=REQUIRED_IF_EOA_FINAL_GOVERNANCE_OWNER
# TIMELOCK_EXECUTOR_PRIVATE_KEY=REQUIRED_IF_ACCEPTING_OWNERSHIP_VIA_TIMELOCK
# TIMELOCK_ACCEPT_ETA=REQUIRED_IF_ACCEPTING_OWNERSHIP_VIA_TIMELOCK

# ---------------------------------------------------------------------------
# Deploy core
# ---------------------------------------------------------------------------

INITIAL_OWNER=REQUIRED_INITIAL_OWNER
INITIAL_GUARDIAN=REQUIRED_INITIAL_GUARDIAN
TIMELOCK_MIN_DELAY=86400

DEFAULT_MAKER_NOTIONAL_FEE_BPS=2
DEFAULT_MAKER_PREMIUM_CAP_BPS=4
DEFAULT_TAKER_NOTIONAL_FEE_BPS=5
DEFAULT_TAKER_PREMIUM_CAP_BPS=6
FEE_BPS_CAP=100

# Use an existing Base Sepolia ERC20 address or the MockUSDC address printed by
# DeployTestnetAssets.s.sol.
BASE_COLLATERAL_TOKEN=REQUIRED_BASE_SEPOLIA_USDC_OR_TESTNET_MOCK_USDC
ETH_UNDERLYING=REQUIRED_BASE_SEPOLIA_ETH_UNDERLYING_OR_TESTNET_MOCK_WETH
BTC_UNDERLYING=REQUIRED_BASE_SEPOLIA_BTC_UNDERLYING_OR_TESTNET_MOCK_WBTC

# ---------------------------------------------------------------------------
# DeployCore outputs
# ---------------------------------------------------------------------------

COLLATERAL_VAULT=FILL_FROM_DEPLOY_CORE_COLLATERAL_VAULT
ORACLE_ROUTER=FILL_FROM_DEPLOY_CORE_ORACLE_ROUTER
OPTION_PRODUCT_REGISTRY=FILL_FROM_DEPLOY_CORE_OPTION_PRODUCT_REGISTRY
MARGIN_ENGINE=FILL_FROM_DEPLOY_CORE_MARGIN_ENGINE
RISK_MODULE=FILL_FROM_DEPLOY_CORE_RISK_MODULE
PERP_MARKET_REGISTRY=FILL_FROM_DEPLOY_CORE_PERP_MARKET_REGISTRY
PERP_ENGINE=FILL_FROM_DEPLOY_CORE_PERP_ENGINE
PERP_RISK_MODULE=FILL_FROM_DEPLOY_CORE_PERP_RISK_MODULE
COLLATERAL_SEIZER=FILL_FROM_DEPLOY_CORE_COLLATERAL_SEIZER
FEES_MANAGER=FILL_FROM_DEPLOY_CORE_FEES_MANAGER
INSURANCE_FUND=FILL_FROM_DEPLOY_CORE_INSURANCE_FUND
MATCHING_ENGINE=FILL_FROM_DEPLOY_CORE_MATCHING_ENGINE
PERP_MATCHING_ENGINE=FILL_FROM_DEPLOY_CORE_PERP_MATCHING_ENGINE
PROTOCOL_TIMELOCK=FILL_FROM_DEPLOY_CORE_PROTOCOL_TIMELOCK
RISK_GOVERNOR=FILL_FROM_DEPLOY_CORE_RISK_GOVERNOR

# ---------------------------------------------------------------------------
# Configure core
# ---------------------------------------------------------------------------

BASE_COLLATERAL_DECIMALS=6
BASE_MAINTENANCE_MARGIN_PER_CONTRACT_BASE=10000000
IM_FACTOR_BPS=12000
ORACLE_DOWN_MM_MULTIPLIER_BPS=20000
RISK_MAX_ORACLE_DELAY=600
PERP_RISK_MAX_ORACLE_DELAY=600
COLLATERAL_RESTRICTION_MODE=true
ALLOW_COLLATERAL_AS_SETTLEMENT_ASSETS=false

# Base-only initial collateral configuration for rehearsal safety.
COLLATERAL_TOKENS=REQUIRED_BASE_SEPOLIA_USDC_OR_TESTNET_MOCK_USDC
COLLATERAL_DECIMALS=6
COLLATERAL_FACTORS_BPS=10000
COLLATERAL_WEIGHTS_BPS=10000
COLLATERAL_DEPOSIT_CAPS=REQUIRED_BASE_COLLATERAL_DEPOSIT_CAP_NATIVE
COLLATERAL_LAUNCH_ACTIVE=true
COLLATERAL_RISK_ENABLED=true
INSURANCE_TOKEN_ALLOWED=true
INSURANCE_OPERATORS=REQUIRED_INSURANCE_OPERATOR

# ---------------------------------------------------------------------------
# Oracle sources
# ---------------------------------------------------------------------------

# Use production-like Base Sepolia source adapters if available, or controlled
# MockPriceSource contracts from DeployTestnetMockFeeds.s.sol.
ETH_USDC_PRIMARY_SOURCE=REQUIRED_ETH_USDC_PRIMARY_SOURCE
ETH_USDC_SECONDARY_SOURCE=REQUIRED_ETH_USDC_SECONDARY_SOURCE_OR_ZERO
ETH_USDC_MAX_DELAY=60
ETH_USDC_MAX_DEVIATION_BPS=1000
ETH_USDC_FEED_ACTIVE=true

BTC_USDC_PRIMARY_SOURCE=REQUIRED_BTC_USDC_PRIMARY_SOURCE
BTC_USDC_SECONDARY_SOURCE=REQUIRED_BTC_USDC_SECONDARY_SOURCE_OR_ZERO
BTC_USDC_MAX_DELAY=60
BTC_USDC_MAX_DEVIATION_BPS=1000
BTC_USDC_FEED_ACTIVE=true

ORACLE_ROUTER_MAX_DELAY=600

# Mock feed prices in 1e8 units. Used only by testnet mock feed scripts.
ETH_USDC_MOCK_PRICE_1E8=300000000000
BTC_USDC_MOCK_PRICE_1E8=6500000000000

# ---------------------------------------------------------------------------
# Option config
# ---------------------------------------------------------------------------

ETH_OPTION_ORACLE=REQUIRED_ETH_OPTION_ORACLE_SOURCE_OR_ROUTER
ETH_OPTION_SPOT_SHOCK_DOWN_BPS=3000
ETH_OPTION_SPOT_SHOCK_UP_BPS=3000
ETH_OPTION_VOL_SHOCK_DOWN_BPS=0
ETH_OPTION_VOL_SHOCK_UP_BPS=2000
ETH_OPTION_UNDERLYING_ENABLED=true
ETH_OPTION_BASE_MM_PER_CONTRACT_BASE=10000000
ETH_OPTION_IM_FACTOR_BPS=12000
ETH_OPTION_ORACLE_DOWN_MM_MULTIPLIER_BPS=20000

BTC_OPTION_ORACLE=REQUIRED_BTC_OPTION_ORACLE_SOURCE_OR_ROUTER
BTC_OPTION_SPOT_SHOCK_DOWN_BPS=2500
BTC_OPTION_SPOT_SHOCK_UP_BPS=2500
BTC_OPTION_VOL_SHOCK_DOWN_BPS=0
BTC_OPTION_VOL_SHOCK_UP_BPS=1500
BTC_OPTION_UNDERLYING_ENABLED=true
BTC_OPTION_BASE_MM_PER_CONTRACT_BASE=8000000
BTC_OPTION_IM_FACTOR_BPS=11000
BTC_OPTION_ORACLE_DOWN_MM_MULTIPLIER_BPS=20000

ETH_OPTION_SERIES_EXPIRIES=REQUIRED_FUTURE_EXPIRY_UNIX
ETH_OPTION_SERIES_STRIKES_1E8=REQUIRED_ETH_STRIKE_1E8
ETH_OPTION_SERIES_IS_CALLS=true
ETH_OPTION_SERIES_IS_EUROPEAN=true
ETH_OPTION_SERIES_REGISTRY_ACTIVE=false
ETH_OPTION_SERIES_ACTIVATION_STATES=0
ETH_OPTION_SERIES_SHORT_OI_CAPS=REQUIRED_ETH_OPTION_SHORT_OI_CAP_1E8

BTC_OPTION_SERIES_EXPIRIES=REQUIRED_FUTURE_EXPIRY_UNIX
BTC_OPTION_SERIES_STRIKES_1E8=REQUIRED_BTC_STRIKE_1E8
BTC_OPTION_SERIES_IS_CALLS=true
BTC_OPTION_SERIES_IS_EUROPEAN=true
BTC_OPTION_SERIES_REGISTRY_ACTIVE=false
BTC_OPTION_SERIES_ACTIVATION_STATES=0
BTC_OPTION_SERIES_SHORT_OI_CAPS=REQUIRED_BTC_OPTION_SHORT_OI_CAP_1E8

# ---------------------------------------------------------------------------
# Perp config
# ---------------------------------------------------------------------------

ETH_PERP_SYMBOL=ETH-PERP
ETH_PERP_ORACLE=FILL_FROM_DEPLOY_CORE_ORACLE_ROUTER
ETH_PERP_REGISTRY_ACTIVE=false
ETH_PERP_CLOSE_ONLY=true
ETH_PERP_ENGINE_ACTIVATION_STATE=0
ETH_PERP_LAUNCH_OI_CAP_1E8=REQUIRED_ETH_PERP_LAUNCH_OI_CAP_1E8
ETH_PERP_INITIAL_MARGIN_BPS=1000
ETH_PERP_MAINTENANCE_MARGIN_BPS=750
ETH_PERP_LIQUIDATION_PENALTY_BPS=500
ETH_PERP_MAX_POSITION_SIZE_1E8=REQUIRED_ETH_PERP_MAX_POSITION_SIZE_1E8
ETH_PERP_MAX_OPEN_INTEREST_1E8=REQUIRED_ETH_PERP_MAX_OPEN_INTEREST_1E8
ETH_PERP_REDUCE_ONLY_DURING_CLOSE_ONLY=true
ETH_PERP_LIQUIDATION_CLOSE_FACTOR_BPS=5000
ETH_PERP_LIQUIDATION_PRICE_SPREAD_BPS=100
ETH_PERP_MIN_LIQUIDATION_IMPROVEMENT_BPS=50
ETH_PERP_LIQUIDATION_ORACLE_MAX_DELAY=60
ETH_PERP_FUNDING_ENABLED=false
ETH_PERP_FUNDING_INTERVAL=0
ETH_PERP_MAX_FUNDING_RATE_BPS=0
ETH_PERP_MAX_SKEW_FUNDING_BPS=0
ETH_PERP_ORACLE_CLAMP_BPS=0

BTC_PERP_SYMBOL=BTC-PERP
BTC_PERP_ORACLE=FILL_FROM_DEPLOY_CORE_ORACLE_ROUTER
BTC_PERP_REGISTRY_ACTIVE=false
BTC_PERP_CLOSE_ONLY=true
BTC_PERP_ENGINE_ACTIVATION_STATE=0
BTC_PERP_LAUNCH_OI_CAP_1E8=REQUIRED_BTC_PERP_LAUNCH_OI_CAP_1E8
BTC_PERP_INITIAL_MARGIN_BPS=1200
BTC_PERP_MAINTENANCE_MARGIN_BPS=800
BTC_PERP_LIQUIDATION_PENALTY_BPS=400
BTC_PERP_MAX_POSITION_SIZE_1E8=REQUIRED_BTC_PERP_MAX_POSITION_SIZE_1E8
BTC_PERP_MAX_OPEN_INTEREST_1E8=REQUIRED_BTC_PERP_MAX_OPEN_INTEREST_1E8
BTC_PERP_REDUCE_ONLY_DURING_CLOSE_ONLY=true
BTC_PERP_LIQUIDATION_CLOSE_FACTOR_BPS=5000
BTC_PERP_LIQUIDATION_PRICE_SPREAD_BPS=80
BTC_PERP_MIN_LIQUIDATION_IMPROVEMENT_BPS=50
BTC_PERP_LIQUIDATION_ORACLE_MAX_DELAY=60
BTC_PERP_FUNDING_ENABLED=false
BTC_PERP_FUNDING_INTERVAL=0
BTC_PERP_MAX_FUNDING_RATE_BPS=0
BTC_PERP_MAX_SKEW_FUNDING_BPS=0
BTC_PERP_ORACLE_CLAMP_BPS=0

# ---------------------------------------------------------------------------
# Ownership handoff
# ---------------------------------------------------------------------------

TIMELOCK_PROPOSERS=FILL_FROM_DEPLOY_CORE_RISK_GOVERNOR
TIMELOCK_PROPOSER_ALLOWED=true
TIMELOCK_EXECUTORS=REQUIRED_TIMELOCK_EXECUTOR
TIMELOCK_EXECUTOR_ALLOWED=true

MATCHING_EXECUTORS=REQUIRED_OPTIONS_MATCHING_EXECUTOR
MATCHING_EXECUTOR_ALLOWED=true
PERP_MATCHING_EXECUTORS=REQUIRED_PERP_MATCHING_EXECUTOR
PERP_MATCHING_EXECUTOR_ALLOWED=true

# Optional mock feed ownership transfer. Keep lengths matched.
# PRICE_SOURCES=FILL_AFTER_TESTNET_FEEDS_ETH_PRIMARY,FILL_AFTER_TESTNET_FEEDS_ETH_SECONDARY,FILL_AFTER_TESTNET_FEEDS_BTC_PRIMARY,FILL_AFTER_TESTNET_FEEDS_BTC_SECONDARY
# PRICE_SOURCE_OWNERS=REQUIRED_PRICE_SOURCE_OWNER,REQUIRED_PRICE_SOURCE_OWNER,REQUIRED_PRICE_SOURCE_OWNER,REQUIRED_PRICE_SOURCE_OWNER
