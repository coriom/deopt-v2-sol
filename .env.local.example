# ---------------------------------------------------------------------------
# Verify deployment
# ---------------------------------------------------------------------------

# VerifyDeployment reuses the core addresses, collateral arrays, oracle feed
# values, option values, and perp values above. Keep those values synchronized
# with any changes made during ConfigureCore or ConfigureMarkets.

# ---------------------------------------------------------------------------
# Transfer ownerships
# ---------------------------------------------------------------------------

# Static Anvil governance placeholders. For this local example the final owner
# is an EOA so AcceptOwnerships can complete without a timelock accept proposal.
GOVERNANCE_OWNER=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
TIMELOCK_OWNER=0x70997970C51812dc3A010C7d01b50e0d17dc79C8
