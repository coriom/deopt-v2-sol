# DeOpt v2 local Anvil rehearsal environment.
#
# Local-only file. Do not reuse these private keys, owner accounts, mock token
# addresses, mock feed addresses, or deployment placeholders outside a throwaway
# Anvil chain.
#
# Values marked FILL_FROM_DEPLOY_CORE_OUTPUT must be replaced with addresses
# printed by script/DeployCore.s.sol before running WireCore and later phases.
#
# Values marked FILL_AFTER_MOCK_DEPLOYMENT must be replaced after deploying
# local mock tokens and local MockPriceSource contracts.

# ---------------------------------------------------------------------------
# Common / chain
# ---------------------------------------------------------------------------

# Static for a default local Anvil node.
RPC_URL=http://127.0.0.1:8545
CHAIN_ID=31337

# Static Anvil account 0. Local only. Never use outside Anvil.
